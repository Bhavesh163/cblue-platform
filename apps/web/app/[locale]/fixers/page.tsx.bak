              : "Hub for fixers, project teams, professionals, and property listers. Register as a partner or access your dashboard, jobs, chat, notifications, and profile."}
          </p>
          <div className="w-20 h-1 bg-sky-500 mx-auto rounded-full mt-4" />
        </div>

        {/* Login Area at Top */}
        <div className="mb-8 bg-white rounded-2xl shadow-lg border border-gray-100 p-6">
          <div className="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div>
              <h2 className="text-lg font-semibold text-gray-800">
                {locale === "th" ? "เข้าสู่ระบบพาร์ทเนอร์" : locale === "zh" ? "合作伙伴登录" : "Partner Login"}
              </h2>
              <p className="text-sm text-gray-500 mt-1">
                {locale === "th" ? "เข้าถึงแดชบอร์ด งาน แชท การแจ้งเตือน และโปรไฟล์ของคุณ" : locale === "zh" ? "访问控制面板、工作、聊天、通知和个人资料" : "Access your dashboard, jobs, chat, notifications, and profile"}
