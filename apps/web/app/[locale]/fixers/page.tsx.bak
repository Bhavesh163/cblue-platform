                    { name: "Customer #B7K", msg: locale === "th" ? "วันไหนสะดวกคะ?" : "Which day works for you?", time: "30m ago", unread: true },
                    { name: "Customer #C4M", msg: locale === "th" ? "งานเสร็จแล้วครับ ขอบคุณ" : "Job is done, thanks!", time: "2h ago", unread: false },
