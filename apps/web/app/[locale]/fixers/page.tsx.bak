                { label: locale === "th" ? "งานที่เสร็จแล้ว" : "Completed", value: DEMO_PARTNER_STATS.completedJobs, icon: "✅", color: "from-green-500 to-emerald-600" },
                { label: locale === "th" ? "รายได้เดือนนี้" : "Monthly Earnings", value: DEMO_PARTNER_STATS.monthlyEarnings, icon: "💰", color: "from-amber-500 to-orange-600" },
                { label: locale === "th" ? "คะแนนเฉลี่ย" : "Rating", value: `${DEMO_PARTNER_STATS.rating} ⭐`, icon: "🏆", color: "from-purple-500 to-indigo-600" },
