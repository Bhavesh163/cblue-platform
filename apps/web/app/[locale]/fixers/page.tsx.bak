                : "One-time processing fee paid by customers per fixer/professional matching"}
            </p>
            <div className="overflow-x-auto">
              <table className="w-full text-sm">
                <thead>
                  <tr className="border-b-2 border-gray-200">
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ระดับ" : locale === "zh" ? "等级" : "Tier"}
                    </th>
                    <th className="text-center py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ค่าประสานงาน" : locale === "zh" ? "服务费" : "Processing Fee"}
                    </th>
                    <th className="text-center py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ระดับดาว" : locale === "zh" ? "星级" : "Star Rating"}
                    </th>
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "คุณสมบัติ" : locale === "zh" ? "资质" : "Qualifications"}
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {[
                    { tier: "Economy", thTier: "Economy", fee: "฿200", stars: "⭐", qual: locale === "th" ? "ช่างทั่วไป ประสบการณ์เบื้องต้น" : locale === "zh" ? "普通技工，基础经验" : "General fixer, basic experience", color: "bg-green-50 text-green-700" },
                    { tier: "Standard", thTier: "Standard", fee: "฿400", stars: "⭐⭐", qual: locale === "th" ? "ช่างมีประสบการณ์ ผลงานดี" : locale === "zh" ? "有经验的技工，良好业绩" : "Experienced fixer, good track record", color: "bg-blue-50 text-blue-700" },
                    { tier: "Corporate", thTier: "Corporate", fee: "฿600", stars: "⭐⭐⭐", qual: locale === "th" ? "ช่างมืออาชีพ หรือทีมงาน" : locale === "zh" ? "专业技工或团队" : "Professional fixer or team", color: "bg-purple-50 text-purple-700" },
                    { tier: "Specialist", thTier: "Specialist", fee: "฿800", stars: "⭐⭐⭐⭐", qual: locale === "th" ? "ผู้เชี่ยวชาญเฉพาะทาง มีใบรับรอง" : locale === "zh" ? "持证专家" : "Certified specialist", color: "bg-amber-50 text-amber-700" },
                    { tier: "Expert", thTier: "Expert", fee: "฿1,000", stars: "⭐⭐⭐⭐⭐", qual: locale === "th" ? "ผู้เชี่ยวชาญระดับสูง ประสบการณ์ 10+ ปี" : locale === "zh" ? "高级专家，10年以上经验" : "Senior expert, 10+ years experience", color: "bg-red-50 text-red-700" },
                  ].map((row) => (
                    <tr key={row.tier} className="border-b border-gray-100 hover:bg-gray-50 transition">
                      <td className="py-3 px-4">
                        <span className={`inline-block px-3 py-1 rounded-full text-xs font-bold ${row.color}`}>{row.tier}</span>
                      </td>
                      <td className="py-3 px-4 text-center font-bold text-gray-900">{row.fee}</td>
                      <td className="py-3 px-4 text-center">{row.stars}</td>
                      <td className="py-3 px-4 text-gray-600">{row.qual}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p className="text-xs text-gray-400 mt-4 text-center">
              {locale === "th"
                ? "* ค่าประสานงานเป็นค่าบริการแพลตฟอร์ม ไม่รวมค่าจ้างช่าง ลูกค้าตกลงราคากับช่างโดยตรง"
                : locale === "zh"
                ? "* 服务费为平台费用，不包含技工费用。客户直接与技工协商价格"
                : "* Processing fee is a platform fee, does not include fixer charges. Customers negotiate pricing directly with fixers."}
            </p>
          </div>
        </div>

        {/* Tier Qualification — Past Project Experience */}
        <div className="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden mt-8">
          <div className="h-3 bg-gradient-to-r from-purple-500 to-indigo-600" />
          <div className="p-8">
            <h2 className="text-2xl font-bold text-gray-900 mb-2 text-center">
              {locale === "th" ? "คุณสมบัติระดับช่าง (Tier Qualification)" : locale === "zh" ? "技工等级资质" : "Tier Qualification Criteria"}
            </h2>
            <p className="text-gray-500 text-sm text-center mb-6">
              {locale === "th"
                ? "ระดับบริการกำหนดจากประสบการณ์ ผลงาน และใบรับรอง"
                : locale === "zh"
                ? "服务等级根据经验、业绩和证书确定"
                : "Service tier is determined by experience, track record, and certifications."}
            </p>
            <div className="overflow-x-auto">
              <table className="w-full text-sm">
                <thead>
                  <tr className="border-b-2 border-gray-200">
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ระดับ" : locale === "zh" ? "等级" : "Tier"}
                    </th>
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ประสบการณ์ขั้นต่ำ" : locale === "zh" ? "最低经验" : "Min. Experience"}
                    </th>
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ผลงานอ้างอิง" : locale === "zh" ? "参考项目" : "Past Projects"}
                    </th>
                    <th className="text-left py-3 px-4 font-semibold text-gray-700">
                      {locale === "th" ? "ใบรับรอง/ใบอนุญาต" : locale === "zh" ? "证书/许可证" : "Certifications"}
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {[
                    { tier: "Economy", exp: locale === "th" ? "1+ ปี" : "1+ years", projects: locale === "th" ? "ไม่จำเป็น" : "Not required", certs: locale === "th" ? "ไม่จำเป็น" : "Not required", color: "bg-green-50 text-green-700" },
                    { tier: "Standard", exp: locale === "th" ? "3+ ปี" : "3+ years", projects: locale === "th" ? "3+ โปรเจกต์" : "3+ projects", certs: locale === "th" ? "แนะนำ" : "Recommended", color: "bg-blue-50 text-blue-700" },
                    { tier: "Corporate", exp: locale === "th" ? "5+ ปี" : "5+ years", projects: locale === "th" ? "10+ โปรเจกต์" : "10+ projects", certs: locale === "th" ? "จำเป็น" : "Required", color: "bg-purple-50 text-purple-700" },
                    { tier: "Specialist", exp: locale === "th" ? "7+ ปี" : "7+ years", projects: locale === "th" ? "20+ โปรเจกต์" : "20+ projects", certs: locale === "th" ? "จำเป็น + เฉพาะทาง" : "Required + specialized", color: "bg-amber-50 text-amber-700" },
                    { tier: "Expert", exp: locale === "th" ? "10+ ปี" : "10+ years", projects: locale === "th" ? "50+ โปรเจกต์" : "50+ projects", certs: locale === "th" ? "จำเป็น + ขั้นสูง" : "Required + advanced", color: "bg-red-50 text-red-700" },
                  ].map((row) => (
                    <tr key={row.tier} className="border-b border-gray-100 hover:bg-gray-50 transition">
                      <td className="py-3 px-4">
                        <span className={`inline-block px-3 py-1 rounded-full text-xs font-bold ${row.color}`}>{row.tier}</span>
                      </td>
                      <td className="py-3 px-4 text-gray-600">{row.exp}</td>
                      <td className="py-3 px-4 text-gray-600">{row.projects}</td>
                      <td className="py-3 px-4 text-gray-600">{row.certs}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p className="text-xs text-gray-400 mt-4 text-center">
              {locale === "th"
                ? "* ช่างสามารถอัปเกรดระดับได้เมื่อมีคุณสมบัติครบถ้วน โดยส่งหลักฐานผ่านแดชบอร์ด"
                : locale === "zh"
                ? "* 技工可在满足条件后通过控制面板提交证据升级等级"
                : "* Fixers can upgrade their tier when qualifications are met by submitting evidence through the dashboard."}
            </p>
          </div>
        </div>
      </div>
    </div>
  );
}
