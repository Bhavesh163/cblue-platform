                    { msg: locale === "th" ? "คุณมีคำขอใหม่ 2 รายการ" : "You have 2 new requests", time: "15m ago", dot: "bg-amber-500" },
                    { msg: locale === "th" ? "การชำระเงินจาก #C4M สำเร็จ" : "Payment from #C4M completed", time: "1h ago", dot: "bg-green-500" },
