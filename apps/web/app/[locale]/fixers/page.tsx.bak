"use client";

import { useState, useEffect } from "react";
import Link from "next/link";
import { useTranslations, useLocale } from "next-intl";

const DEMO_PARTNER_STATS = {
  activeJobs: 3,
  completedJobs: 47,
  monthlyEarnings: "฿18,500",
  rating: 4.8,
};

const DEMO_ACTIVE_JOBS = [
  { id: 1, service: "Plumbing Repair", serviceTh: "ซ่อมประปา", customer: "Customer #A2X", tier: "Standard", date: "2025-01-15", status: "IN_PROGRESS" },
  { id: 2, service: "AC Maintenance", serviceTh: "ซ่อมแอร์", customer: "Customer #B7K", tier: "Corporate", date: "2025-01-16", status: "CONFIRMED" },
  { id: 3, service: "Electrical Wiring", serviceTh: "งานไฟฟ้า", customer: "Customer #C4M", tier: "Economy", date: "2025-01-17", status: "PENDING" },
];

const DEMO_INCOMING_REQUESTS = [
  { id: 4, service: "Interior Design", serviceTh: "ออกแบบภายใน", customer: "Customer #D9P", tier: "Specialist", date: "2025-01-18", budget: "฿15,000" },
  { id: 5, service: "Landscaping", serviceTh: "จัดสวน", customer: "Customer #E3R", tier: "Expert", date: "2025-01-19", budget: "฿25,000" },
];

export default function FixerProPage() {
  const t = useTranslations("nav");
