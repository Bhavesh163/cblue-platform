{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cblue-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets"
  },
  "pages_build_output_dir": ".open-next/assets"
}
