{
  "main": ".open-next/worker.js",
  "name": "cblue-web",
  "compatibility_date": "2026-04-14",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "routes": [
    { "pattern": "cblue.co.th/*", "zone_name": "cblue.co.th" },
    { "pattern": "www.cblue.co.th/*", "zone_name": "cblue.co.th" }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Environment variables available to the worker
  // DNS-only A record: api-backend.cblue.co.th → 168.144.39.0
  // CF Workers cannot fetch bare IPs (error 1003), so we use a real subdomain
  "vars": {
    "API_BACKEND_URL": "http://api-backend.cblue.co.th"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "cblue-web"
    }
  ]
}
